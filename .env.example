# Encore config. Copy to .env and fill in. NEVER commit real values.

# --- Backblaze B2 (scoped application key, NOT the master key) ---
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_REGION=us-west-004
# Optional Cloudflare hostname fronting the bucket (zero-egress public URLs)
B2_PUBLIC_URL_BASE=

# --- Local backends ---
COMFY_SERVER=127.0.0.1:8188
# Workflow templates the ComfyUI provider loads (one JSON per model)
COMFY_WORKFLOWS=./workflows

# --- Self-correction identity judge (local) ---
JUDGE_STRATEGY=ollama
OLLAMA_VISION_MODEL=qwen3-vl:8b-instruct
JUDGE_PASS_THRESHOLD=0.8

# --- Public demo ---
# 1 = gallery public but generation locked to the local box
PUBLIC_DEMO_FORCE=
