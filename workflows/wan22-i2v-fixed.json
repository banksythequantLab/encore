{
  "id": "wan22-i2v-fixed",
  "name": "Wan 2.2 I2V 14B (Distilled 4-Step) - schema-fixed",
  "type": "video",
  "description": "Image-to-video using Wan 2.2 14B FP8 with LightX2V distillation. Two-pass sampling in 4 steps. WanImageToVideo now receives start_image + width/height/length/batch_size and drives both samplers (positive[95,0]/negative[95,1]/latent[95,2]); CLIPVisionEncode has required crop.",
  "inputs": {
    "prompt": { "nodeId": "89", "field": "text", "label": "Prompt", "type": "string" },
    "image": { "nodeId": "100", "field": "image", "label": "Input Image", "type": "string" },
    "width": { "nodeId": "95", "field": "width", "label": "Width", "type": "number", "default": 832 },
    "height": { "nodeId": "95", "field": "height", "label": "Height", "type": "number", "default": 480 },
    "length": { "nodeId": "95", "field": "length", "label": "Frame Count", "type": "number", "default": 49 },
    "frame_count": { "nodeId": "95", "field": "length", "label": "Frame Count", "type": "number", "default": 49 },
    "seed": { "nodeId": "81", "field": "noise_seed", "label": "Seed", "type": "number", "default": -1 },
    "frame_rate": { "nodeId": "88", "field": "fps", "label": "FPS", "type": "number", "default": 16 },
    "filename_prefix": { "nodeId": "80", "field": "filename_prefix", "label": "Filename Prefix", "type": "string", "hidden": true }
  },
  "outputs": {
    "video": { "nodeId": "80", "class_type": "SaveVideo" }
  },
  "workflow": {
    "71": {
      "inputs": {
        "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
        "type": "wan",
        "device": "default"
      },
      "class_type": "CLIPLoader",
      "_meta": { "title": "Load CLIP" }
    },
    "72": {
      "inputs": {
        "text": "blurry, low quality, static, distorted, deformed, bad anatomy, watermark, text, subtitles",
        "clip": ["71", 0]
      },
      "class_type": "CLIPTextEncode",
      "_meta": { "title": "CLIP Text Encode (Negative)" }
    },
    "73": {
      "inputs": {
        "vae_name": "wan_2.1_vae.safetensors"
      },
      "class_type": "VAELoader",
      "_meta": { "title": "Load VAE" }
    },
    "75": {
      "inputs": {
        "unet_name": "wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors",
        "weight_dtype": "default"
      },
      "class_type": "UNETLoader",
      "_meta": { "title": "Load I2V High Noise Model" }
    },
    "76": {
      "inputs": {
        "unet_name": "wan2.2_i2v_low_noise_14B_fp8_scaled.safetensors",
        "weight_dtype": "default"
      },
      "class_type": "UNETLoader",
      "_meta": { "title": "Load I2V Low Noise Model" }
    },
    "78": {
      "inputs": {
        "add_noise": "disable",
        "noise_seed": 0,
        "steps": 4,
        "cfg": 1,
        "sampler_name": "euler",
        "scheduler": "simple",
        "start_at_step": 2,
        "end_at_step": 4,
        "return_with_leftover_noise": "disable",
        "model": ["86", 0],
        "positive": ["95", 0],
        "negative": ["95", 1],
        "latent_image": ["81", 0]
      },
      "class_type": "KSamplerAdvanced",
      "_meta": { "title": "KSampler Pass 2 (Low Noise)" }
    },
    "80": {
      "inputs": {
        "filename_prefix": "video/ComfyUI",
        "format": "auto",
        "codec": "auto",
        "video": ["88", 0]
      },
      "class_type": "SaveVideo",
      "_meta": { "title": "Save Video" }
    },
    "81": {
      "inputs": {
        "add_noise": "enable",
        "noise_seed": 392459563371087,
        "steps": 4,
        "cfg": 1,
        "sampler_name": "euler",
        "scheduler": "simple",
        "start_at_step": 0,
        "end_at_step": 2,
        "return_with_leftover_noise": "enable",
        "model": ["82", 0],
        "positive": ["95", 0],
        "negative": ["95", 1],
        "latent_image": ["95", 2]
      },
      "class_type": "KSamplerAdvanced",
      "_meta": { "title": "KSampler Pass 1 (High Noise)" }
    },
    "82": {
      "inputs": {
        "shift": 5.0,
        "model": ["83", 0]
      },
      "class_type": "ModelSamplingSD3",
      "_meta": { "title": "ModelSamplingSD3 (High Noise)" }
    },
    "83": {
      "inputs": {
        "lora_name": "wan2.2_i2v_lightx2v_4steps_lora_v1_high_noise.safetensors",
        "strength_model": 1.0,
        "model": ["75", 0]
      },
      "class_type": "LoraLoaderModelOnly",
      "_meta": { "title": "I2V LightX2V LoRA (High Noise)" }
    },
    "85": {
      "inputs": {
        "lora_name": "wan2.2_i2v_lightx2v_4steps_lora_v1_low_noise.safetensors",
        "strength_model": 1.0,
        "model": ["76", 0]
      },
      "class_type": "LoraLoaderModelOnly",
      "_meta": { "title": "I2V LightX2V LoRA (Low Noise)" }
    },
    "86": {
      "inputs": {
        "shift": 5.0,
        "model": ["85", 0]
      },
      "class_type": "ModelSamplingSD3",
      "_meta": { "title": "ModelSamplingSD3 (Low Noise)" }
    },
    "87": {
      "inputs": {
        "samples": ["78", 0],
        "vae": ["73", 0]
      },
      "class_type": "VAEDecode",
      "_meta": { "title": "VAE Decode" }
    },
    "88": {
      "inputs": {
        "fps": 16,
        "images": ["87", 0]
      },
      "class_type": "CreateVideo",
      "_meta": { "title": "Create Video" }
    },
    "89": {
      "inputs": {
        "text": "cinematic video, smooth camera movement, high quality",
        "clip": ["71", 0]
      },
      "class_type": "CLIPTextEncode",
      "_meta": { "title": "CLIP Text Encode (Positive)" }
    },
    "95": {
      "inputs": {
        "width": 832,
        "height": 480,
        "length": 49,
        "batch_size": 1,
        "positive": ["89", 0],
        "negative": ["72", 0],
        "vae": ["73", 0],
        "clip_vision_output": ["92", 0],
        "start_image": ["100", 0]
      },
      "class_type": "WanImageToVideo",
      "_meta": { "title": "Wan Image To Video" }
    },
    "91": {
      "inputs": {
        "clip_name": "clip_vision_h.safetensors"
      },
      "class_type": "CLIPVisionLoader",
      "_meta": { "title": "Load CLIP Vision" }
    },
    "92": {
      "inputs": {
        "image": ["100", 0],
        "clip_vision": ["91", 0],
        "crop": "center"
      },
      "class_type": "CLIPVisionEncode",
      "_meta": { "title": "CLIP Vision Encode" }
    },
    "100": {
      "inputs": {
        "image": "input_image.png"
      },
      "class_type": "LoadImage",
      "_meta": { "title": "Load Input Image" }
    }
  }
}
